{{!-- Character Conflict Panel — read-only display when character is in an active conflict --}}
<section class="character-conflict-panel {{#unless conflict.active}}hidden{{/unless}}">
{{#if conflict.active}}

  {{!-- Header bar with conflict type + HP --}}
  <div class="conflict-panel-header">
    <span class="conflict-panel-title">
      <i class="fa-solid fa-shield-halved"></i>
      {{conflict.typeLabel}}
    </span>
    <span class="conflict-panel-hp">
      {{localize "TB2E.Conflict.HP"}}: {{conflict.hp.value}}/{{conflict.hp.max}}
    </span>
    <div class="conflict-panel-hp-bar">
      <div class="conflict-panel-hp-fill" style="width: {{conflict.hpPercent}}%"></div>
    </div>
  </div>

  {{!-- Captain status --}}
  {{#if conflict.isCaptain}}
  <div class="conflict-panel-role">
    <span class="conflict-role-badge captain">
      <i class="fa-solid fa-star"></i> {{localize "TB2E.Conflict.Captain"}}
    </span>
  </div>
  {{/if}}

  {{!-- Weapon picker (during weapons phase) --}}
  {{#if conflict.isWeapons}}
  <div class="conflict-panel-section">
    <div class="conflict-section-label">{{localize "TB2E.Conflict.Weapon"}}</div>
    {{#if conflict.usesGear}}
    <div class="conflict-weapon-area">
      <select class="conflict-weapon-select">
        <option value="">{{localize "TB2E.Conflict.WeaponChoose"}}</option>
        {{#each conflict.weaponChoices}}
        <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
        {{/each}}
      </select>
      <input type="text" class="conflict-weapon-improvised-input {{#unless conflict.isImprovised}}hidden{{/unless}}"
             value="{{#if conflict.isImprovised}}{{conflict.weapon}}{{/if}}"
             placeholder="{{localize 'TB2E.Conflict.WeaponImprovisedPlaceholder'}}">
    </div>
    {{else}}
    <div class="conflict-weapon-area">
      <input type="text" class="conflict-weapon-input" value="{{conflict.weapon}}"
             placeholder="{{localize 'TB2E.Conflict.WeaponPlaceholder'}}">
    </div>
    {{/if}}
  </div>
  {{/if}}

  {{!-- Weapon display (shown after weapons phase) --}}
  {{#if conflict.isScriptingOrResolve}}
    {{#if conflict.weapon}}
    <div class="conflict-panel-weapon-display {{#if conflict.isUnarmed}}weapon-unarmed{{/if}}">
      {{#if conflict.isUnarmed}}
      <i class="fa-solid fa-hand-fist"></i>
      <em>{{localize "TB2E.Conflict.WeaponUnarmed"}}</em>
      <span class="weapon-penalty-badge">-1D</span>
      {{else if conflict.isImprovised}}
      <i class="fa-solid fa-sword"></i>
      <em>{{conflict.weapon}}</em>
      {{else}}
      <i class="fa-solid fa-sword"></i> {{conflict.weapon}}
      {{/if}}
    </div>
    {{/if}}
  {{/if}}

  {{!-- Phase label --}}
  <div class="conflict-panel-phase">
    {{conflict.phase}}
  </div>

{{/if}}
</section>
