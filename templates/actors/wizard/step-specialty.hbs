{{!-- Step 5: Specialty --}}
<div class="wizard-step step-specialty">
  <h2 class="step-heading">{{localize "TB2E.Wizard.Step.Specialty"}}</h2>
  <p class="step-instructions">{{localize "TB2E.Wizard.SpecialtyInstructions"}}</p>

  <div class="skill-choice-grid">
    {{#each specialtySkills}}
    <div class="skill-choice-card{{#if isSelected}} selected{{/if}}"
         role="button" tabindex="0"
         data-action="selectSpecialty" data-skill="{{key}}">
      <span class="skill-name">{{label}}</span>
      {{#if isIncrease}}
      <span class="skill-change">{{currentRating}} &rarr; {{newRating}}</span>
      {{else}}
      <span class="skill-rating">{{newRating}}</span>
      {{/if}}
    </div>
    {{/each}}
  </div>
</div>
