{{!-- Step 2: Upbringing (Human/Changeling only) --}}
<div class="wizard-step step-upbringing">
  <h2 class="step-heading">{{localize "TB2E.Wizard.Step.Upbringing"}}</h2>
  <p class="step-instructions">{{localize "TB2E.Wizard.UpbringingInstructions"}}</p>

  <div class="skill-choice-grid">
    {{#each upbringingSkills}}
    <div class="skill-choice-card{{#if isSelected}} selected{{/if}}"
         role="button" tabindex="0"
         data-action="selectUpbringing" data-skill="{{key}}">
      <span class="skill-name">{{label}}</span>
      {{#if isIncrease}}
      <span class="skill-change">{{currentRating}} &rarr; {{newRating}}</span>
      {{else}}
      <span class="skill-rating">{{newRating}}</span>
      {{/if}}
    </div>
    {{/each}}
  </div>
</div>
