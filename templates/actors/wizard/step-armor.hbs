{{!-- Step 11: Armor --}}
<div class="wizard-step step-armor">
  <h2 class="step-heading">{{localize "TB2E.Wizard.Step.Armor"}}</h2>
  <p class="step-instructions">{{localize "TB2E.Wizard.ArmorInstructions"}}</p>

  {{#if autoLeather}}
  <p class="auto-armor-note">{{localize "TB2E.Wizard.AutoLeather"}}</p>
  {{/if}}

  {{#if noArmor}}
  <p class="no-armor-note">{{localize "TB2E.Wizard.NoStartingArmor"}}</p>
  {{/if}}

  {{!-- Helmet (outcast/warrior only, if no shield) --}}
  {{#if canHelmet}}
  <div class="armor-section">
    <h3>{{localize "TB2E.Armor.Helmet"}}</h3>
    <div class="armor-card{{#if helmetSelected}} selected{{/if}}"
         role="button" tabindex="0"
         data-action="selectArmor" data-armor="Helmet">
      <span class="armor-name">{{localize "TB2E.Armor.Helmet"}}</span>
    </div>
  </div>
  {{/if}}

  {{#if shieldBlocksHelmet}}
  <p class="shield-blocks-note">{{localize "TB2E.Wizard.HelmetBlockedByShield"}}</p>
  {{/if}}

  {{#if selectedArmor.length}}
  <div class="selected-summary">
    <h3>{{localize "TB2E.Wizard.SelectedArmor"}}</h3>
    {{#each selectedArmor}}
    <span class="armor-badge">{{this}}</span>
    {{/each}}
  </div>
  {{/if}}
</div>
