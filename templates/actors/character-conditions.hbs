<nav class="conditions-strip">
  {{#each conditions}}
  <button type="button" class="condition-btn{{#if active}} active{{/if}}"
          data-action="toggleCondition" data-condition="{{key}}"
          style="--cond-color: var({{color}})" title="{{label}}">
    <i class="{{icon}}"></i>
    <span class="condition-label">{{label}}</span>
  </button>
  {{/each}}
</nav>
