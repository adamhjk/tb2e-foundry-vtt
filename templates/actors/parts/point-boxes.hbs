{{!--
  Point boxes for Fate/Persona display.
  Expected context:
    label   - localized label ("Fate" or "Persona")
    path    - data path prefix (e.g. "system.fate")
    current - current points available
    spent   - points spent lifetime
    icon    - FontAwesome icon class
--}}
<div class="point-boxes" data-page="{{page}}">
  <span class="point-label"><i class="{{icon}}"></i> {{label}}</span>
  <input type="number" class="point-current-input" name="{{path}}.current"
         value="{{current}}" min="0"
         title="{{localize 'TB2E.Fields.Current'}}">
  <span class="point-spent-label">{{localize "TB2E.Fields.Spent"}}:</span>
  <input type="number" class="point-spent-input" name="{{path}}.spent"
         value="{{spent}}" min="0"
         title="{{localize 'TB2E.Fields.Spent'}}">
</div>
