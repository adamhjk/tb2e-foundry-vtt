{{!-- Conflict Resolution Window --}}
{{#if hasConflict}}
<div class="conflict-window-content">

  {{!-- Header --}}
  <div class="cw-header">
    <span class="cw-title">
      {{conflictTypeLabel}} — {{localize "TB2E.Conflict.Round"}} {{roundNum}}
    </span>
  </div>

  {{!-- Two-column grid: Team | Reveal | Team --}}
  <div class="cw-grid">

    {{!-- Team columns --}}
    {{#each teams}}
    <div class="cw-team" data-group-id="{{this.id}}">

      {{!-- Team header --}}
      <div class="cw-team-header">
        <span class="cw-team-name">{{this.name}}</span>
        {{#if this.isPlayerTeam}}
        <button type="button" class="cw-peek-btn" data-action="togglePeek"
                title="{{localize 'TB2E.Conflict.PeekActions'}}">
          <i class="fa-solid {{#if this.gmPeeking}}fa-eye{{else}}fa-eye-slash{{/if}}"></i>
        </button>
        {{/if}}
        <span class="cw-team-disp">{{this.currentDisp}} / {{this.maxDisp}}</span>
      </div>

      {{!-- Volleys --}}
      {{#each this.volleys}}
      <div class="cw-volley" data-volley="{{this.index}}">
        <div class="cw-volley-header">
          <span class="cw-volley-badge">{{this.volleyNum}}</span>

          {{!-- Combatant selector --}}
          {{#if ../showActions}}
          {{#unless this.isLocked}}
          <select class="cw-combatant-select" data-volley="{{this.index}}">
            <option value="">— {{localize "TB2E.Conflict.SelectActor"}} —</option>
            {{#each this.memberOptions}}
            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>
              {{this.name}}
            </option>
            {{/each}}
          </select>
          {{else}}
          <span class="cw-volley-actor">
            {{#if this.selectedCombatantImg}}
            <img class="cw-volley-actor-img" src="{{this.selectedCombatantImg}}" alt="">
            {{/if}}
            {{this.selectedCombatantName}}
          </span>
          {{/unless}}
          {{else}}
          {{!-- Opponent side: show name if revealed, otherwise hidden --}}
          {{#if this.isRevealed}}
          <span class="cw-volley-actor">
            {{#if this.selectedCombatantImg}}
            <img class="cw-volley-actor-img" src="{{this.selectedCombatantImg}}" alt="">
            {{/if}}
            {{this.selectedCombatantName}}
          </span>
          {{else}}
          <span class="cw-volley-actor cw-hidden-actor">???</span>
          {{/if}}
          {{/if}}
        </div>

        {{!-- Action selection area --}}
        <div class="cw-actions">
          {{#if this.isLocked}}
            {{!-- Locked --}}
            {{#if this.isRevealed}}
              {{!-- Revealed: show the selected action card --}}
              <div class="cw-card-row">
                <div class="cw-card just-revealed" data-action-key="{{this.selectedAction}}">
                  <div class="cw-card-face">
                    <span class="cw-card-pip top-left">{{this.selectedActionPip}}<i class="{{this.selectedActionIcon}}"></i></span>
                    <span class="cw-card-pip bottom-right">{{this.selectedActionPip}}<i class="{{this.selectedActionIcon}}"></i></span>
                    <i class="cw-card-icon {{this.selectedActionIcon}}"></i>
                    <span class="cw-card-label">{{this.selectedActionLabel}}</span>
                  </div>
                </div>
              </div>
            {{else}}
              {{#if ../showActions}}
                {{!-- Own team: show face-up but dimmed --}}
                <div class="cw-card-row">
                  <div class="cw-card own-locked" data-action-key="{{this.selectedAction}}">
                    <div class="cw-card-face">
                      <span class="cw-card-pip top-left">{{this.selectedActionPip}}<i class="{{this.selectedActionIcon}}"></i></span>
                      <span class="cw-card-pip bottom-right">{{this.selectedActionPip}}<i class="{{this.selectedActionIcon}}"></i></span>
                      <i class="cw-card-icon {{this.selectedActionIcon}}"></i>
                      <span class="cw-card-label">{{this.selectedActionLabel}}</span>
                    </div>
                  </div>
                </div>
              {{else}}
                {{!-- Opposing team: show face-down card --}}
                <div class="cw-card-row">
                  <div class="cw-card face-down">
                    <div class="cw-card-back">
                      <div class="cw-card-back-pattern"></div>
                      <div class="cw-card-back-emblem"><i class="fa-solid fa-shield-halved"></i></div>
                    </div>
                  </div>
                </div>
              {{/if}}
            {{/if}}
          {{else}}
            {{!-- Unlocked: show action cards --}}
            {{#if ../showActions}}
              <div class="cw-card-row">
                {{#each this.actionButtons}}
                <div class="cw-card {{#if this.selected}}selected{{/if}}"
                     data-action="setVolleyAction" data-action-key="{{this.key}}">
                  <div class="cw-card-face">
                    <span class="cw-card-pip top-left">{{this.pip}}<i class="{{this.icon}}"></i></span>
                    <span class="cw-card-pip bottom-right">{{this.pip}}<i class="{{this.icon}}"></i></span>
                    <i class="cw-card-icon {{this.icon}}"></i>
                    <span class="cw-card-label">{{this.label}}</span>
                  </div>
                </div>
                {{/each}}
              </div>
            {{else}}
              <div class="cw-card-row">
                <div class="cw-card face-down">
                  <div class="cw-card-back">
                    <div class="cw-card-back-pattern"></div>
                    <div class="cw-card-back-emblem"><i class="fa-solid fa-shield-halved"></i></div>
                  </div>
                </div>
              </div>
            {{/if}}
          {{/if}}
        </div>
      </div>
      {{/each}}

      {{!-- Lock button --}}
      <div class="cw-team-footer">
        {{#if this.isLocked}}
          <div class="cw-locked-badge">
            <i class="fa-solid fa-lock"></i> {{localize "TB2E.Conflict.ActionsLocked"}}
          </div>
        {{else if this.canLock}}
          <button type="button" class="cw-lock-btn" data-action="lockActions">
            <i class="fa-solid fa-lock"></i> {{localize "TB2E.Conflict.LockActions"}}
          </button>
        {{/if}}
      </div>
    </div>

    {{!-- Reveal column (inserted after first team) --}}
    {{#if @first}}
    <div class="cw-reveal-column">
      <div class="cw-reveal-spacer"></div>
      {{#each @root.teams.[0].volleys}}
      <div class="cw-reveal-cell" data-volley="{{this.index}}">
        {{#if this.isRevealed}}
          <span class="cw-revealed-icon"><i class="fa-solid fa-eye"></i></span>
        {{else if @root.allLocked}}
          {{#if @root.isGM}}
          <button type="button" class="cw-reveal-btn" data-action="revealVolley" data-volley="{{this.index}}"
                  title="{{localize 'TB2E.Conflict.Reveal'}}">
            <i class="fa-solid fa-eye"></i>
          </button>
          {{else}}
          <span class="cw-waiting-icon"><i class="fa-solid fa-eye-slash"></i></span>
          {{/if}}
        {{else}}
          <span class="cw-waiting-icon"><i class="fa-solid fa-eye-slash"></i></span>
        {{/if}}
      </div>
      {{/each}}
      <div class="cw-reveal-spacer"></div>
    </div>
    {{/if}}
    {{/each}}
  </div>

  {{!-- Resolution area for revealed volleys --}}
  {{#if allLocked}}
  {{#each revealedVolleys}}
  <div class="cw-resolution" data-volley="{{this.index}}">
    <div class="cw-resolution-header">
      <span class="cw-resolution-badge">{{localize "TB2E.Conflict.Volley"}} {{this.volleyNum}}</span>
      {{#if this.hasResult}}
      <span class="cw-resolution-resolved"><i class="fa-solid fa-check"></i> {{localize "TB2E.Conflict.Resolved"}}</span>
      {{/if}}
    </div>
    <div class="cw-resolution-matchup">
      {{#each this.sides}}
      <div class="cw-resolution-side">
        <span class="cw-resolution-actor">{{this.combatantName}}</span>
        <span class="cw-resolution-action cw-action-{{this.action}}">{{this.actionLabel}}</span>
        <span class="cw-resolution-interaction interaction-{{this.interaction}}">
          {{this.interactionLabel}}
        </span>
      </div>
      {{#unless @last}}<span class="cw-vs">vs</span>{{/unless}}
      {{/each}}
    </div>
    {{#unless this.hasResult}}
      {{#if @root.isGM}}
      <div class="cw-resolution-controls">
        <button type="button" class="cw-roll-btn" data-action="rollVolley" data-volley="{{this.index}}">
          <i class="fa-solid fa-dice"></i> {{localize "TB2E.Conflict.ResolveVolley"}}
        </button>
      </div>
      {{/if}}
    {{/unless}}
  </div>
  {{/each}}
  {{/if}}

  {{!-- Footer: New Round / End Conflict --}}
  {{#if isGM}}
  {{#if allResolved}}
  <div class="cw-footer">
    <button type="button" class="cw-new-round-btn" data-action="newRound">
      <i class="fa-solid fa-forward"></i> {{localize "TB2E.Conflict.NewRound"}}
    </button>
    <button type="button" class="cw-end-conflict-btn" data-action="endConflict">
      <i class="fa-solid fa-flag-checkered"></i> {{localize "TB2E.Conflict.EndConflict"}}
    </button>
  </div>
  {{/if}}
  {{/if}}

</div>
{{else}}
<div class="cw-empty">
  <p>{{localize "TB2E.Conflict.NoConflict"}}</p>
</div>
{{/if}}
