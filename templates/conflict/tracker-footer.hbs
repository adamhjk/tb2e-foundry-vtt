{{!-- Conflict Tracker Footer --}}
<div class="tb2e-conflict-footer">
  {{#if isGM}}

    {{#unless hasCombat}}
    <div class="create-conflict-controls">
      <select class="conflict-type-select">
        {{#each conflictTypes}}
        <option value="{{key}}">{{label}}</option>
        {{/each}}
      </select>
      <button type="button" class="conflict-control" data-action="createConflict">
        <i class="fa-solid fa-shield-halved"></i>
        {{localize "TB2E.Conflict.CreateConflict"}}
      </button>
    </div>
    {{/unless}}

    {{#if isSetup}}
    <button type="button" class="conflict-control" data-action="beginRolling"
            {{#unless canBeginRolling}}disabled{{/unless}}>
      <i class="fa-solid fa-dice"></i>
      {{localize "TB2E.Conflict.BeginRolling"}}
    </button>
    {{/if}}

    {{#if isWeapons}}
    <button type="button" class="conflict-control" data-action="beginScripting">
      <i class="fa-solid fa-scroll"></i>
      {{localize "TB2E.Conflict.BeginScripting"}}
    </button>
    {{/if}}

  {{/if}}

  {{#if isRolling}}
  <div class="phase-indicator">
    <i class="fa-solid fa-dice"></i>
    {{localize "TB2E.Conflict.Phase.Rolling"}}
  </div>
  {{/if}}

  {{#if isDistribution}}
  <div class="phase-indicator">
    <i class="fa-solid fa-scale-balanced"></i>
    {{localize "TB2E.Conflict.Phase.Distribution"}}
  </div>
  {{/if}}

  {{#if isWeapons}}
  <div class="phase-indicator">
    <i class="fa-solid fa-sword"></i>
    {{localize "TB2E.Conflict.Phase.Weapons"}}
  </div>
  {{/if}}

  {{#if isScriptingOrActive}}
    <button type="button" class="conflict-control" data-action="openConflictWindow">
      <i class="fa-solid fa-swords"></i>
      {{localize "TB2E.Conflict.OpenConflictWindow"}}
    </button>
    {{#if isGM}}
    <button type="button" class="conflict-control" data-action="endConflict">
      <i class="fa-solid fa-flag-checkered"></i>
      {{localize "TB2E.Conflict.EndConflict"}}
    </button>
    {{/if}}
  {{/if}}
</div>
