{{!-- Resolve Tab --}}
<div class="panel-tab-content resolve-tab">

  {{#if pendingEffects.length}}
  <div class="pending-maneuver-effects">
    {{#each pendingEffects}}
    <div class="pending-effect-row">
      <span class="pending-effect-group">{{this.groupName}}:</span>
      {{#if this.impede}}
      <span class="pending-effect-chip impede"><i class="fa-solid fa-arrow-down"></i> -{{this.impede}}D {{localize "TB2E.Conflict.Maneuver.Impede"}}</span>
      {{/if}}
      {{#if this.position}}
      <span class="pending-effect-chip position"><i class="fa-solid fa-arrow-up"></i> +{{this.position}}D {{localize "TB2E.Conflict.Maneuver.Position"}}</span>
      {{/if}}
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#each resolveActions}}
  <div class="resolve-action {{#if this.isCurrent}}current{{/if}} {{#if this.isPast}}past{{/if}} {{#if this.isFuture}}future{{/if}}">
    <div class="resolve-action-header">
      <span class="resolve-action-num">{{localize "TB2E.Conflict.ActionLabel"}} {{this.actionNum}}</span>
      {{#if this.hasResult}}
      <span class="resolve-action-status resolved"><i class="fa-solid fa-check"></i> {{localize "TB2E.Conflict.Resolved"}}</span>
      {{else if this.isRevealed}}
      <span class="resolve-action-status revealed"><i class="fa-solid fa-eye"></i></span>
      {{/if}}
    </div>

    {{#if this.isCurrent}}
    <div class="resolve-action-body">

      {{!-- Not yet revealed --}}
      {{#unless this.isRevealed}}
        {{!-- Pre-reveal swap for KO'd combatants (GM only) --}}
        {{#if @root.isGM}}
        {{#each this.sides}}
        {{#if this.needsSwap}}
        <div class="resolve-pre-swap">
          <span class="resolve-ko-warning"><i class="fa-solid fa-skull"></i> {{this.combatantName}} — {{localize "TB2E.Conflict.KnockedOutLabel"}}</span>
          {{#if this.swapCandidates.length}}
          <select class="resolve-swap-select" data-group-id="{{this.groupId}}">
            <option value="">{{localize "TB2E.Conflict.SwapCombatant"}}</option>
            {{#each this.swapCandidates}}
            <option value="{{this.id}}">{{this.name}}</option>
            {{/each}}
          </select>
          {{/if}}
        </div>
        {{/if}}
        {{/each}}
        {{/if}}

        {{#if @root.isGM}}
        <button type="button" class="panel-action-btn" data-action="revealAction">
          <i class="fa-solid fa-eye"></i> {{localize "TB2E.Conflict.Reveal"}} {{this.actionNum}}
        </button>
        {{else}}
        <div class="resolve-waiting">
          <i class="fa-solid fa-hourglass-half"></i>
          {{localize "TB2E.Conflict.WaitingForReveal"}}
        </div>
        {{/if}}
      {{else}}

      {{!-- Revealed: show matchup with styled action cards --}}
      <div class="resolve-matchup">
        {{#each this.sides}}
        <div class="resolve-side">
          <span class="resolve-side-actor {{#if this.needsSwap}}knocked-out{{/if}}">{{this.combatantName}}{{#if this.needsSwap}} <i class="fa-solid fa-skull" title="{{localize 'TB2E.Conflict.KnockedOutLabel'}}"></i>{{/if}}</span>
          {{#if this.needsSwap}}
          {{#if this.swapCandidates.length}}
          <select class="resolve-swap-select" data-group-id="{{this.groupId}}">
            <option value="">{{localize "TB2E.Conflict.SwapCombatant"}}</option>
            {{#each this.swapCandidates}}
            <option value="{{this.id}}">{{this.name}}</option>
            {{/each}}
          </select>
          {{/if}}
          {{/if}}
          <div class="resolve-action-card action-card-{{this.action}}">
            <i class="{{this.actionIcon}}"></i>
            <span class="action-card-label">{{this.actionLabel}}</span>
          </div>
          <span class="resolve-side-test">{{this.testLabel}}</span>
          {{!-- Per-side interaction --}}
          {{#if this.interactionOverridable}}
          <select class="side-interaction-select"
                  data-action-index="{{../index}}" data-group-id="{{this.groupId}}">
            <option value="versus" {{#if (eq this.sideInteraction "versus")}}selected{{/if}}>{{lookup @root.interactionLabels "versus"}}</option>
            <option value="independent" {{#if (eq this.sideInteraction "independent")}}selected{{/if}}>{{lookup @root.interactionLabels "independent"}}</option>
            <option value="none" {{#if (eq this.sideInteraction "none")}}selected{{/if}}>{{lookup @root.interactionLabels "none"}}</option>
          </select>
          {{else if this.sideInteraction}}
          <span class="resolve-side-interaction interaction-{{this.sideInteraction}}">
            {{lookup @root.interactionLabels this.sideInteraction}}
          </span>
          {{/if}}
          {{!-- Roll button: only for character owner or GM --}}
          {{#unless ../../hasResult}}
          {{#if this.canRoll}}
          <button type="button" class="panel-action-btn resolve-side-roll-btn {{#if (eq this.sideInteraction "none")}}invisible{{/if}}" data-action="rollAction"
                  data-actor-id="{{this.actorId}}" data-combatant-id="{{this.combatantId}}"
                  data-conflict-action="{{this.action}}"
                  data-group-id="{{this.groupId}}" {{#if (eq this.sideInteraction "none")}}disabled{{/if}}>
            <i class="fa-solid fa-dice"></i> {{localize "TB2E.Conflict.Roll"}} {{this.testLabel}}
          </button>
          {{/if}}
          {{/unless}}
        </div>
        {{#unless @last}}<span class="resolve-vs">vs</span>{{/unless}}
        {{/each}}
      </div>

      {{!-- Mark resolved button --}}
      {{#unless this.hasResult}}
      <div class="resolve-roll-buttons">
        {{#if @root.isGM}}
        <button type="button" class="panel-action-btn secondary" data-action="resolveAction"
                data-action-index="{{this.index}}">
          <i class="fa-solid fa-check"></i> {{localize "TB2E.Conflict.MarkResolved"}}
        </button>
        {{/if}}
      </div>
      {{/unless}}

      {{/unless}}
    </div>
    {{/if}}

    {{!-- Past action: compact summary with icons --}}
    {{#if this.isPast}}
    {{#if this.isRevealed}}
    <div class="resolve-action-summary">
      {{#each this.sides}}
      <span class="resolve-summary-side action-{{this.action}}">
        {{#if this.actionIcon}}<i class="{{this.actionIcon}}"></i> {{/if}}{{this.combatantName}}: {{this.actionLabel}}
      </span>
      {{/each}}
      {{#if this.interactionLabel}}
      <span class="resolve-summary-interaction">({{this.interactionLabel}})</span>
      {{/if}}
      {{#if this.maneuverUnspent}}
      <span class="maneuver-unspent-pill" title="{{localize 'TB2E.Conflict.Maneuver.UnspentHint'}}">
        <i class="fa-solid fa-crosshairs"></i> {{localize "TB2E.Conflict.Maneuver.Unspent"}}
      </span>
      {{else if this.maneuverSpent}}
      <span class="maneuver-spent-pill" title="{{localize 'TB2E.Conflict.Maneuver.SpentHint'}}">
        <i class="fa-solid fa-check"></i> {{localize "TB2E.Conflict.Maneuver.Spent"}}
      </span>
      {{/if}}
    </div>
    {{/if}}
    {{/if}}
  </div>
  {{/each}}

  {{!-- Navigation buttons --}}
  {{#if isGM}}
  <div class="resolve-nav">
    {{#if canResolveConflict}}
    <button type="button" class="setup-next-btn" data-action="resolveConflict">
      <span class="setup-next-label">{{localize "TB2E.Conflict.ResolveConflict"}}</span>
      <i class="fa-solid fa-arrow-right"></i>
    </button>
    {{else if allResolved}}
    <button type="button" class="setup-next-btn" data-action="nextRound">
      <span class="setup-next-label">{{localize "TB2E.Conflict.NewRound"}}</span>
      <i class="fa-solid fa-arrow-right"></i>
    </button>
    {{/if}}
  </div>
  {{/if}}

</div>
