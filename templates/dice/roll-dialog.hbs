<div class="tb2e-roll-dialog-form">
  <div class="roll-dialog-header">
    {{#unless disposition}}
    <button type="button" class="roll-dialog-badge roll-dialog-mode-toggle">
      <span class="mode-label">{{independentLabel}}</span>
      <i class="fa-solid fa-caret-down mode-caret"></i>
    </button>
    <input type="hidden" name="mode" value="independent">
    {{/unless}}
    <h3 class="roll-dialog-title">{{label}}</h3>
  </div>

  <div class="roll-dialog-fields">
    <div class="roll-field">
      <label for="poolSize">{{dicePoolLabel}}</label>
      <input type="number" name="poolSize" id="poolSize" value="{{dice}}" min="0" max="20" autofocus>
    </div>
    {{#unless disposition}}
    <div class="roll-field roll-field-obstacle">
      <label for="obstacle">{{obstacleLabel}}</label>
      <input type="number" name="obstacle" id="obstacle" value="1" min="0" max="20">
    </div>
    {{/unless}}
  </div>

  {{#unless disposition}}
  <div class="roll-dialog-challenge hidden">
    <label>{{challengeLabel}}</label>
    <select name="challengeMessageId">
      <option value="">{{newChallengeLabel}}</option>
      {{#each openChallenges}}
      <option value="{{messageId}}" data-actor-name="{{actorName}}">{{actorName}} — {{label}} Test</option>
      {{/each}}
    </select>
  </div>
  {{/unless}}

  {{#if modifiers.length}}
  <div class="roll-dialog-modifiers">
    {{#each modifiers}}
    <div class="roll-modifier" style="--mod-color: var({{color}})">
      <i class="{{icon}}"></i>
      <span class="mod-label">{{label}}</span>
      <span class="mod-value">{{display}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if hasHelpers}}
  <div class="roll-dialog-helpers">
    <div class="helpers-heading">
      <i class="fa-solid fa-handshake-angle"></i>
      <span>{{helpLabel}}</span>
    </div>
    {{#if pcHelpers.length}}
    <div class="helpers-list">
      {{#each pcHelpers}}
      <button type="button" class="helper-toggle" data-helper-id="{{id}}" data-help-via="{{helpVia}}">
        <span class="helper-name">{{name}}</span>
        <span class="helper-via">{{helpViaLabel}}</span>
        <span class="helper-dice">+1D</span>
        {{#if warnings.length}}
        <span class="helper-warning" title="{{#each warnings}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}"><i class="fa-solid fa-triangle-exclamation"></i></span>
        {{/if}}
      </button>
      {{/each}}
    </div>
    {{/if}}
    {{#if npcHelpers.length}}
    <details class="helpers-npc-group">
      <summary class="helpers-npc-heading">
        <i class="fa-solid fa-users"></i>
        <span>{{npcHelpLabel}}</span>
        <span class="helpers-npc-count">({{npcHelpers.length}})</span>
      </summary>
      <div class="helpers-list">
        {{#each npcHelpers}}
        <button type="button" class="helper-toggle" data-helper-id="{{id}}" data-help-via="{{helpVia}}">
          <span class="helper-name">{{name}}</span>
          <span class="helper-via">{{helpViaLabel}}</span>
          <span class="helper-dice">+1D</span>
          {{#if warnings.length}}
          <span class="helper-warning" title="{{#each warnings}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}"><i class="fa-solid fa-triangle-exclamation"></i></span>
          {{/if}}
        </button>
        {{/each}}
      </div>
    </details>
    {{/if}}
  </div>
  {{/if}}

  {{#unless disposition}}
  <div class="roll-dialog-options">
    <label class="roll-option">
      <input type="checkbox" name="logAdvancement" checked>
      <span>{{advancementLabel}}</span>
    </label>
  </div>
  {{/unless}}

  <div class="roll-dialog-summary">
    <i class="fa-solid fa-dice"></i>
    <span class="roll-dialog-summary-text">{{#if disposition}}{{total}}D{{else}}{{total}}D vs Ob 1{{/if}}</span>
  </div>
</div>
