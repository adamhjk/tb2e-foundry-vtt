<div class="tb2e-chat-card">
  <div class="card-header card-header--centered">
    <span class="card-label">{{versusTestLabel}}</span>
  </div>

  <div class="versus-combatants">
    <div class="versus-combatant {{#if initiatorWins}}versus-winner{{/if}}">
      <img class="versus-portrait" src="{{initiatorImg}}" alt="{{initiatorName}}">
      <span class="versus-name">{{initiatorName}}</span>
      <span class="versus-skill">{{initiatorLabel}}</span>
      <span class="versus-successes">{{initiatorSuccesses}} {{successesLabel}}</span>
    </div>

    <div class="versus-divider">VS</div>

    <div class="versus-combatant {{#unless initiatorWins}}versus-winner{{/unless}}">
      <img class="versus-portrait" src="{{opponentImg}}" alt="{{opponentName}}">
      <span class="versus-name">{{opponentName}}</span>
      <span class="versus-skill">{{opponentLabel}}</span>
      <span class="versus-successes">{{opponentSuccesses}} {{successesLabel}}</span>
    </div>
  </div>

  {{#if tiebrokenBy}}
  <div class="card-body">
    <p class="versus-tiebroken">{{tiebrokenBy}}</p>
  </div>
  {{/if}}

  <div class="card-banner banner-pass">
    {{#if initiatorWins}}
    <span class="versus-winner-name">{{initiatorName}}</span>
    {{else}}
    <span class="versus-winner-name">{{opponentName}}</span>
    {{/if}}
    <span>{{winsLabel}}</span>
  </div>

  {{#if showManeuverSpend}}
  <div class="maneuver-spend-prompt-card">
    <button type="button" class="card-btn card-btn--amber" data-action="spend-maneuver">
      <i class="fa-solid fa-crosshairs"></i> {{maneuverSpendLabel}}
    </button>
  </div>
  {{/if}}
</div>
