<div class="tb2e-chat-card card-accent--amber grind-condition-card">
  <div class="card-header">
    <img class="card-portrait" src="{{actorImg}}" alt="{{actorName}}">
    <div class="card-info">
      <span class="card-name">{{actorName}}</span>
      <span class="card-label">{{label}}</span>
    </div>
  </div>
  <div class="card-body">
    <p>{{body}}</p>
    <p class="grind-condition-name">{{condLabel}}</p>
  </div>
  <div class="card-actions">
    <button type="button" class="card-btn card-btn--amber" data-action="applyGrindCondition">
      {{applyLabel}}
    </button>
  </div>
</div>
