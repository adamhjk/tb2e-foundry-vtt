<div class="tb2e-chat-card">
  <div class="card-header">
    <img class="card-portrait" src="{{actorImg}}" alt="{{actorName}}">
    <div class="card-info">
      <span class="card-name">{{actorName}}</span>
      {{#if actorSubtitle}}
      <span class="card-subtitle">{{actorSubtitle}}</span>
      {{/if}}
      {{#if isDisposition}}
      <span class="card-context">{{conflictTypeLabel}} {{conflictTitle}} — {{groupName}}</span>
      {{/if}}
      <span class="card-label">
        {{testTypeLabel}} {{label}} {{testLabel}}
        {{#if isBL}}
        <span class="roll-card-bl-badge"><i class="fa-solid fa-graduation-cap"></i> BL</span>
        {{/if}}
      </span>
    </div>
  </div>

  <div class="roll-card-breakdown">
    <div class="breakdown-line">
      <i class="fa-solid fa-dice"></i>
      <span class="breakdown-label">{{label}}</span>
      <span class="breakdown-value">{{baseDice}}D</span>
    </div>
    {{#each modifiers}}
    <div class="breakdown-line breakdown-modifier" style="--mod-color: var({{color}})">
      <i class="{{icon}}"></i>
      <span class="breakdown-label">{{label}}</span>
      <span class="breakdown-value">{{display}}</span>
    </div>
    {{/each}}
    <div class="breakdown-total">
      {{#if isDisposition}}<span>{{poolSize}}D</span>
      {{else}}<span>{{poolSize}}D vs Ob {{obstacle}}</span>{{/if}}
    </div>
  </div>

  <div class="roll-card-dice">
    {{#each diceResults}}
    <span class="die-result {{#if isSun}}die-sun{{else if success}}die-success{{else}}die-fail{{/if}}{{#if isRerolled}} die-rerolled{{/if}}{{#if isLuck}} die-luck{{/if}}{{#if isOfCourse}} die-of-course{{/if}}">
      {{#if isSun}}<i class="fa-solid fa-sun"></i>
      {{else if success}}<i class="fa-solid fa-shield-halved"></i>
      {{else}}<i class="fa-solid fa-dragon"></i>
      {{/if}}
    </span>
    {{/each}}
  </div>

  {{! Post-roll success modifiers }}
  {{#if postSuccessMods}}
  <div class="roll-card-post-mods">
    {{#each postSuccessMods}}
    <div class="post-mod-line" style="--mod-color: var({{color}})">
      <i class="{{icon}}"></i>
      <span>{{label}}</span>
      <span class="post-mod-value">{{display}}</span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <div class="roll-card-tally">
    <span class="tally-successes">{{successesLabel}}: {{successes}}</span>
    {{#if isDisposition}}
    <span class="tally-ability">+ {{abilityLabel}}: {{abilityRating}}</span>
    {{else}}
    <span class="tally-obstacle">{{obstacleLabel}}: {{obstacle}}</span>
    {{/if}}
  </div>

  {{! Post-roll action buttons }}
  {{#if hasPostActions}}
  <div class="card-actions" data-message-id="">
    {{#unless deeperUsed}}
      {{#unless luckUsed}}
        {{#if hasFate}}{{#if wiseSelected}}{{#if hasWyrms}}
        <button type="button" class="card-btn card-btn--amber" data-action="deeper-understanding">
          <span class="post-roll-label"><i class="fa-solid fa-lightbulb"></i> Deeper Understanding (Fate 1)</span>
          <span class="post-roll-summary">Reroll 1 Wyrm (SG p. 87)</span>
        </button>
        {{/if}}{{/if}}{{/if}}
      {{/unless}}
    {{/unless}}
    {{#unless ofCourseUsed}}
      {{#unless luckUsed}}
        {{#if hasPersona}}{{#if wiseSelected}}{{#if hasWyrms}}
        <button type="button" class="card-btn card-btn--blue" data-action="of-course">
          <span class="post-roll-label"><i class="fa-solid fa-hat-wizard"></i> Ah, Of Course! (Persona 1)</span>
          <span class="post-roll-summary">Roll {{wyrmCount}} new dice (SG p. 88)</span>
        </button>
        {{/if}}{{/if}}{{/if}}
      {{/unless}}
    {{/unless}}
    {{#unless luckUsed}}
      {{#if hasFate}}{{#if hasSuns}}
      <button type="button" class="card-btn card-btn--amber" data-action="fate-luck">
        <span class="post-roll-label"><i class="fa-solid fa-clover"></i> Fate: Luck (Fate 1)</span>
        <span class="post-roll-summary">Explode {{sunCount}} Suns (SG p. 87)</span>
      </button>
      {{/if}}{{/if}}
    {{/unless}}
    {{#if showNatureTax}}
    <div class="nature-tax-prompt">
      <span>Within Nature descriptors?</span>
      <button type="button" class="card-btn nature-tax-btn" data-action="nature-yes">Yes</button>
      <button type="button" class="card-btn nature-tax-btn" data-action="nature-no">No</button>
    </div>
    {{/if}}
    {{#if showDirectNatureTax}}
    <div class="nature-tax-notice outside">
      <i class="fa-solid fa-paw"></i> {{localize "TB2E.Nature.OutsideDescriptors"}} — {{localize "TB2E.Nature.TaxOnFailure"}}
    </div>
    {{/if}}
    {{#if directNatureWithin}}
    <div class="nature-tax-notice within">
      <i class="fa-solid fa-paw"></i> {{localize "TB2E.Nature.ActingWithin"}} — no tax
    </div>
    {{/if}}
    <button type="button" class="card-btn card-btn--green" data-action="finalize">
      <i class="fa-solid fa-check-double"></i> Finalize
    </button>
  </div>
  {{/if}}

  {{#if synergyHelpers.length}}
  <div class="roll-card-helpers">
    <div class="section-label"><i class="fa-solid fa-handshake-angle"></i> Helper Synergy</div>
    {{#each synergyHelpers}}
    <button type="button" class="card-btn card-btn--amber" data-action="synergy" data-helper-id="{{id}}">
      <span class="post-roll-label"><i class="fa-solid fa-star"></i> {{name}}: Synergy (Fate 1)</span>
      <span class="post-roll-summary">Log {{helpViaLabel}} advancement (SG p. 87)</span>
    </button>
    {{/each}}
  </div>
  {{/if}}

  {{#if isDisposition}}
  <div class="card-banner banner-disposition">
    <i class="fa-solid fa-shield"></i> {{dispositionLabel}}: {{disposition}}
  </div>
  {{else if pass}}
  <div class="card-banner banner-pass">
    <i class="fa-solid fa-check"></i> {{passLabel}} <span class="banner-margin">(MoS {{margin}})</span>
  </div>
  {{else}}
  <div class="card-banner banner-fail">
    <i class="fa-solid fa-xmark"></i> {{failLabel}} <span class="banner-margin">(MoF {{margin}})</span>
  </div>
  {{/if}}
</div>
