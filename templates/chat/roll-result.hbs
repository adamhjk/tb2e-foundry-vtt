<div class="tb2e-roll-card">
  <div class="roll-card-header">
    <img class="roll-card-portrait" src="{{actorImg}}" alt="{{actorName}}">
    <div class="roll-card-info">
      <span class="roll-card-name">{{actorName}}</span>
      {{#if actorSubtitle}}
      <span class="roll-card-subtitle">{{actorSubtitle}}</span>
      {{/if}}
      {{#if isDisposition}}
      <span class="roll-card-context">{{conflictTypeLabel}} {{conflictTitle}} — {{groupName}}</span>
      {{/if}}
      <span class="roll-card-test">{{testTypeLabel}} {{label}} {{testLabel}}</span>
    </div>
  </div>

  <div class="roll-card-breakdown">
    <div class="breakdown-line">
      <i class="fa-solid fa-dice"></i>
      <span class="breakdown-label">{{label}}</span>
      <span class="breakdown-value">{{baseDice}}D</span>
    </div>
    {{#each modifiers}}
    <div class="breakdown-line breakdown-modifier" style="--mod-color: var({{color}})">
      <i class="{{icon}}"></i>
      <span class="breakdown-label">{{label}}</span>
      <span class="breakdown-value">{{display}}</span>
    </div>
    {{/each}}
    <div class="breakdown-total">
      {{#if isDisposition}}<span>{{poolSize}}D</span>
      {{else}}<span>{{poolSize}}D vs Ob {{obstacle}}</span>{{/if}}
    </div>
  </div>

  <div class="roll-card-dice">
    {{#each diceResults}}
    <span class="die-result {{#if isSun}}die-sun{{else if success}}die-success{{else}}die-fail{{/if}}">
      {{#if isSun}}<i class="fa-solid fa-sun"></i>
      {{else if success}}<i class="fa-solid fa-shield-halved"></i>
      {{else}}<i class="fa-solid fa-dragon"></i>
      {{/if}}
    </span>
    {{/each}}
  </div>

  <div class="roll-card-tally">
    <span class="tally-successes">{{successesLabel}}: {{successes}}</span>
    {{#if isDisposition}}
    <span class="tally-ability">+ {{abilityLabel}}: {{abilityRating}}</span>
    {{else}}
    <span class="tally-obstacle">{{obstacleLabel}}: {{obstacle}}</span>
    {{/if}}
  </div>

  {{#if isDisposition}}
  <div class="roll-card-banner banner-disposition">
    <i class="fa-solid fa-shield"></i> {{dispositionLabel}}: {{disposition}}
  </div>
  {{else if pass}}
  <div class="roll-card-banner banner-pass">
    <i class="fa-solid fa-check"></i> {{passLabel}}
  </div>
  {{else}}
  <div class="roll-card-banner banner-fail">
    <i class="fa-solid fa-xmark"></i> {{failLabel}}
  </div>
  {{/if}}
</div>
