{
  "name": "tb2e-foundry-vtt",
  "version": "0.1.0",
  "type": "module",
  "description": "Torchbearer 2nd Edition system for Foundry VTT",
  "license": "mit",
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run build:db",
    "build:css": "lessc less/tb2e.less tb2e.css --source-map",
    "watch:css": "less-watch-compiler less/ ./ tb2e.less --source-map",
    "build:db": "node utils/packs.mjs --compile",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "PWDEBUG=1 playwright test",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^3.0.3",
    "@playwright/test": "^1.50.0",
    "less": "^4.5.1",
    "less-watch-compiler": "^1.17.5"
  }
}
